# @tesserix packages are published to the public npm registry (registry.npmjs.org).
# No scoped registry override needed.

# React Native + new architecture codegen scans node_modules/ flat. pnpm's
# default symlinked layout breaks codegen discovery of native modules
# (react-native-gesture-handler, etc.). Use hoisted layout to mirror npm
# behaviour. Required for `expo run:ios` / `xcodebuild` to find codegen
# headers in apps/mobile-*/ios/build/generated/.
node-linker=hoisted
