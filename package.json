{
  "name": "homechef",
  "version": "1.0.0",
  "private": true,
  "description": "HomeChef - Connect with home chefs for authentic homemade food",
  "keywords": [
    "food-delivery",
    "home-chef",
    "catering",
    "homemade-food"
  ],
  "license": "UNLICENSED",
  "author": "HomeChef Team",
  "scripts": {
    "dev": "pnpm --filter @homechef/web dev",
    "dev:vendor": "pnpm --filter @homechef/vendor-portal dev",
    "dev:delivery": "pnpm --filter @homechef/delivery-portal dev",
    "dev:api": "cd apps/api && go run cmd/server/main.go",
    "dev:customer": "pnpm --filter @homechef/mobile-customer start",
    "dev:mobile-vendor": "pnpm --filter @homechef/mobile-vendor start",
    "dev:mobile-delivery": "pnpm --filter @homechef/mobile-delivery start",
    "dev:landing": "pnpm --filter @homechef/web-landing dev",
    "build:landing": "pnpm --filter @homechef/web-landing build",
    "build:customer": "pnpm --filter @homechef/mobile-customer build:local",
    "build:mobile-vendor": "pnpm --filter @homechef/mobile-vendor build:local",
    "build:mobile-delivery": "pnpm --filter @homechef/mobile-delivery build:local",
    "build": "pnpm --filter @homechef/web build",
    "build:vendor": "pnpm --filter @homechef/vendor-portal build",
    "build:delivery": "pnpm --filter @homechef/delivery-portal build",
    "build:all": "pnpm -r build",
    "lint": "pnpm -r lint",
    "lint:fix": "pnpm -r lint:fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "test": "pnpm -r test",
    "test:coverage": "pnpm -r test:coverage",
    "clean": "pnpm -r clean && rm -rf node_modules",
    "typecheck": "pnpm -r typecheck",
    "prepare": "husky"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "typescript": "^6.0.3"
  },
  "packageManager": "pnpm@9.15.1",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "pnpm": {
    "patchedDependencies": {
      "@tesserix/native": "patches/@tesserix__native.patch"
    },
    "overrides": {
      "vitest": "^3.2.6",
      "@expo/metro-runtime": "^56.0.15",
      "@expo/dom-webview": "^56.0.5",
      "@tootallnate/once": "^2.0.1",
      "@xmldom/xmldom": "^0.8.13",
      "ajv": "^6.14.0",
      "axios": "^1.16.0",
      "brace-expansion@1": "^1.1.13",
      "brace-expansion@2": "^2.0.3",
      "brace-expansion@5": "^5.0.6",
      "esbuild": "^0.25.0",
      "flatted": "^3.4.2",
      "follow-redirects": "^1.16.0",
      "js-yaml@3": "^3.15.0",
      "minimatch@3": "^3.1.4",
      "minimatch@9": "^9.0.7",
      "picomatch@2": "^2.3.2",
      "picomatch@4": "^4.0.4",
      "postcss": "^8.5.10",
      "react-router": "^7.15.0",
      "rollup": "^4.59.0",
      "uuid": "^11.1.1",
      "vite": "^6.4.2",
      "ws": "^8.20.1",
      "yaml": "^2.8.3"
    }
  }
}
