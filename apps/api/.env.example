# Server
PORT=8080
ENVIRONMENT=development

# Database
DATABASE_URL=
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password
DB_NAME=homechef
DB_SSLMODE=disable

# BFF trust — must match apps/auth-bff's SESSION_INTERNAL_HMAC_KEY env.
# 32 random bytes, base64-encoded. Required in every environment.
BFF_INTERNAL_HMAC_KEY=

# Clock-skew tolerance for the X-Auth-Ts header (seconds). Default 60.
BFF_AUTH_TS_WINDOW_SECONDS=60

# OAuth public client IDs only. The OIDC handshake lives in apps/auth-bff
# via Google Identity Platform; client secrets are not held by the API.
GOOGLE_CLIENT_ID=
FACEBOOK_APP_ID=

# Storage
STORAGE_PROVIDER=local
S3_BUCKET=
S3_REGION=us-east-1
S3_ACCESS_KEY=
S3_SECRET_KEY=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=

# Email — SendGrid primary, Resend fallback
SENDGRID_API_KEY=
RESEND_API_KEY=
FROM_EMAIL=noreply@homechef.com
FROM_NAME=HomeChef

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Redis
REDIS_URL=redis://localhost:6379

# Feature Flags
ENABLE_MOCK_MODE=false
# Apply wallet store-credit at checkout (#141). Default off until the Razorpay
# direct-transfer top-up is verified in the Razorpay sandbox.
WALLET_CHECKOUT_ENABLED=false
# Tiffin meal-plan escrow money flow (#194). Default off until sandbox-verified.
MEAL_PLAN_ESCROW_ENABLED=false
