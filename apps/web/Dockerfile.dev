# HomeChef Web — local dev server image.
# Uses the tesserix base-node-builder-22 (corepack + libc6-compat
# pre-baked) so dev matches CI layers. pnpm@9.15.1 is pinned here
# (the base ships corepack but lets each app pick its exact pnpm).
FROM ghcr.io/tesserix/base-node-builder-22:latest
USER 0:0
WORKDIR /app

RUN corepack prepare pnpm@9.15.1 --activate

COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./
COPY apps/web/package.json ./apps/web/

RUN pnpm install --frozen-lockfile

COPY . .

EXPOSE 5173
CMD ["pnpm", "--filter", "@homechef/web", "dev", "--host", "0.0.0.0"]
