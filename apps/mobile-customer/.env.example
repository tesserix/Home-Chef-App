# Copy to .env.local and fill in your values.
# These vars are required at build time — EAS does not read .env files; set
# them in the build profile's `env` block (see eas.json).

EXPO_PUBLIC_API_URL=http://localhost:8080/api/v1
EXPO_PUBLIC_BFF_URL=http://localhost:8081

# GIP tenant pool the customer app authenticates against
EXPO_PUBLIC_GIP_TENANT_ID=HomeChef-Customer-rqg8a
EXPO_PUBLIC_GIP_API_KEY=your-firebase-web-api-key

# Google OAuth client IDs from GCP Console → APIs & Services → Credentials.
# The web client ID is used by @react-native-firebase/auth to verify the GSI
# id_token. The iOS client ID is required for the native iOS sign-in sheet.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=YOUR_GOOGLE_WEB_CLIENT_ID_HERE
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=YOUR_GOOGLE_IOS_CLIENT_ID_HERE
