{
  "cli": {
    "version": ">= 18.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": { "resourceClass": "m-medium" },
      "android": { "buildType": "apk" },
      "env": {
        "EXPO_PUBLIC_API_URL": "http://localhost:8080/api/v1",
        "EXPO_PUBLIC_BFF_URL": "http://localhost:8081",
        "EXPO_PUBLIC_GIP_TENANT_ID": "HomeChef-Customer-rqg8a",
        "EXPO_PUBLIC_GIP_API_KEY": "REPLACE_WITH_FIREBASE_WEB_API_KEY",
        "EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID": "REPLACE_WITH_WEB_OAUTH_CLIENT_ID",
        "EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID": "REPLACE_WITH_IOS_OAUTH_CLIENT_ID"
      }
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "ios": { "resourceClass": "m-medium" },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://api.fe3dr.com/api/v1",
        "EXPO_PUBLIC_BFF_URL": "https://fe3dr.com",
        "EXPO_PUBLIC_GIP_TENANT_ID": "HomeChef-Customer-rqg8a"
      }
    },
    "production": {
      "channel": "production",
      "ios": { "resourceClass": "m-medium" },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://api.fe3dr.com/api/v1",
        "EXPO_PUBLIC_BFF_URL": "https://fe3dr.com",
        "EXPO_PUBLIC_GIP_TENANT_ID": "HomeChef-Customer-rqg8a"
      }
    }
  },
  "submit": {
    "production": {
      "ios": { "appleId": "" },
      "android": { "serviceAccountKeyPath": "" }
    }
  }
}
