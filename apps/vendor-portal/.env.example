# Vendor Portal Environment Variables
# Copy to .env for local development

# Go API base URL
VITE_API_URL=http://localhost:8080/api/v1

# Auth BFF URL — apps/auth-bff (Google Identity Platform / GIP)
VITE_BFF_URL=http://localhost:8090

# Google OAuth client ID used by Google Identity Services (GSI) for the
# inline "Sign in with Google" button. Must match the OAuth client whose
# Authorized JavaScript Origins include this site.
VITE_GOOGLE_CLIENT_ID=849928263410-gri0fclh2pdbkgu3g3ppm6npa3kktib9.apps.googleusercontent.com

# Google Identity Platform (GIP) — public values, shipped in the bundle
VITE_GIP_API_KEY=your-firebase-web-api-key
VITE_GIP_PROJECT_ID=tesseracthub-480811
VITE_GIP_AUTH_DOMAIN=tesseracthub-480811.firebaseapp.com
VITE_GIP_TENANT_ID=HomeChef-Business-8s8ql
