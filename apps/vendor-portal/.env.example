# Vendor Portal Environment Variables
# Copy to .env for local development

# Go API base URL
VITE_API_URL=http://localhost:8080/api/v1

# Auth BFF URL (Keycloak OIDC via identity.fe3dr.com)
VITE_BFF_URL=http://localhost:8090

# Google Identity Platform (GIP) — public values, shipped in the bundle
VITE_GIP_API_KEY=your-firebase-web-api-key
VITE_GIP_PROJECT_ID=tesseracthub-480811
VITE_GIP_AUTH_DOMAIN=tesseracthub-480811.firebaseapp.com
VITE_GIP_TENANT_ID=HomeChef-Business-xxxxx
