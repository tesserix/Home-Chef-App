{
  "expo": {
    "name": "Fe3dr Admin",
    "slug": "homechef-admin",
    "scheme": "homechef-admin",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "jsEngine": "hermes",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "bundleIdentifier": "com.tesserix.homechef.admin",
      "entitlements": {
        "keychain-access-groups": ["$(AppIdentifierPrefix)$(CFBundleIdentifier)"]
      },
      "supportsTablet": true,
      "usesAppleSignIn": true,
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "NSFaceIDUsageDescription": "Use Face ID to unlock the admin console quickly",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.tesserix.homechef.admin",
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-local-authentication",
      "expo-apple-authentication",
      "@react-native-firebase/app",
      "@react-native-firebase/auth",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.REPLACE_WITH_ADMIN_IOS_CLIENT_ID"
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static",
            "deploymentTarget": "18.0",
            "newArchEnabled": true,
            "buildReactNativeFromSource": true
          },
          "android": {
            "newArchEnabled": true
          }
        }
      ],
      "expo-image",
      "expo-web-browser",
      "expo-font",
      [
        "expo-splash-screen",
        {
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0E0E0C"
        }
      ],
      "expo-status-bar"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "REPLACE_WITH_EAS_PROJECT_ID"
      }
    },
    "owner": "tesserix-org"
  }
}
