# Copy to .env.local and fill in your values.
# These vars are required at build time — EAS does not read .env files; set
# them in the build profile's `env` block (see eas.json).

EXPO_PUBLIC_API_URL=http://localhost:8090/api/v1
EXPO_PUBLIC_BFF_URL=http://localhost:8090

# GIP tenant pool the admin app authenticates against. The "internal" pool
# resolves to role=admin in the auth-bff (see homechef-products.yaml). This
# tenant must be present in the BFF's mobileTenantAllowlist.
EXPO_PUBLIC_GIP_TENANT_ID=HomeChef-Internal-gyofe
EXPO_PUBLIC_GIP_API_KEY=your-firebase-web-api-key

# Google OAuth client IDs from GCP Console → APIs & Services → Credentials.
# Web client id is shared with the admin portal; iOS client id must be created
# for the com.tesserix.homechef.admin bundle.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=YOUR_GOOGLE_WEB_CLIENT_ID_HERE
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=YOUR_ADMIN_GOOGLE_IOS_CLIENT_ID_HERE
